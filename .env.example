# Copy to `.env` at the repo root (same folder as `main.py`). Never commit `.env`.
# All real values stay in `.env` or your host (Render/Vercel) secret store.

# --- Groq (LLM) — https://console.groq.com ---
GROQ_API_KEY=
MODEL_NAME=llama-3.3-70b-versatile

# --- Database (local Docker default: user postgres, port 5435 on host) ---
# Password must match POSTGRES_PASSWORD in docker-compose.yml (or your own URL).
DATABASE_URL=postgresql+psycopg://postgres:localdev_not_for_production@localhost:5435/aineta

# --- SMTP (e.g. Gmail app password) ---
SMTP_USERNAME=
SMTP_PASSWORD=
TEST_RECEIVER_EMAIL=
MAIL_FROM=

# Complaint notification safety inbox until production unlock.
DEV_SAFE_INBOX=

# Optional Next admin banner (see README).
# NEXT_PUBLIC_DEV_INBOX=

# DEFAULT_CITY_ID=
# DEFAULT_ADMIN_EMAIL=
# DEFAULT_ADMIN_DEPARTMENT_NAME=

# --- API server ---
# Comma-separated browser origins (no spaces). Required in production.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ADMIN_API_KEY=
AUTH_SECRET_KEY=
# AUTH_TOKEN_TTL_MINUTES=10080

# --- Frontend (prefer frontend/.env.local) ---
# NEXT_PUBLIC_API_URL=http://localhost:8000
# FASTAPI_INTERNAL_URL=http://127.0.0.1:8000
