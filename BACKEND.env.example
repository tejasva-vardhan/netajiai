# =============================================================================
# AI Neta — Backend (FastAPI on Render) — copy to Render Environment or .env
# =============================================================================
# Never commit real secrets. Use your host's secret manager for production values.

# --- Required for production ---
# PostgreSQL (Render Postgres / Neon / etc.). Use TLS in production, e.g. append:
#   ?sslmode=require
# Render often provides postgres:// — this app normalizes it for SQLAlchemy/psycopg3.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Browser origins allowed by CORS (comma-separated, no spaces). Must include your Vercel URL.
# Example: https://aineta.vercel.app,https://www.yourdomain.com
ALLOWED_ORIGINS=https://your-app.vercel.app

# HS256 secret for JWT access tokens (email OTP login). Use a long random string.
AUTH_SECRET_KEY=

# Groq API (chat / complaint AI). Get a key at https://console.groq.com/
GROQ_API_KEY=

# Protects admin and superadmin HTTP APIs. Frontend sends header: x-api-key
# Must match NEXT_PUBLIC_ADMIN_API_KEY on Vercel if you use the admin UI.
ADMIN_API_KEY=

# --- Email (OTP + complaint notifications) ---
# Gmail-style SMTP: create an app password for the sending account.
SMTP_USERNAME=
SMTP_PASSWORD=

# From address for OTP and system mail (must be allowed for that SMTP account).
MAIL_FROM=noreply@yourdomain.com

# When set, complaint notification emails are sent only to this inbox (safety lock).
DEV_SAFE_INBOX=monitoring@yourdomain.com

# Fallback routing labels when no officer mapping exists in DB.
DEFAULT_ADMIN_DEPARTMENT_NAME=Municipal Corporation Helpdesk
DEFAULT_ADMIN_EMAIL=fallback@yourdomain.com

# --- Optional ---
# JWT lifetime in minutes (default: 10080 = 7 days if unset in code paths).
AUTH_TOKEN_TTL_MINUTES=10080

# LLM model id (defaults in code if unset; config.py uses llama-3.3-70b-versatile).
MODEL_NAME=llama-3.3-70b-versatile

# Default city DB id when location cannot be resolved (integer; see seed data).
DEFAULT_CITY_ID=

# --- Platform (Render sets automatically; do not set locally unless needed) ---
# PORT=10000
