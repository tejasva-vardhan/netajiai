# =============================================================================
# AI Neta — Frontend (Next.js on Vercel) — copy to Vercel Environment Variables
# =============================================================================
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser — never put server-only
# secrets there. Keep admin keys scoped and rotate if leaked.

# --- Required for production ---
# Public URL of the FastAPI backend (Render), no trailing slash.
# Example: https://aineta-api.onrender.com
NEXT_PUBLIC_API_URL=https://your-api.onrender.com

# Must match backend ADMIN_API_KEY. Sent as request header x-api-key from admin/superadmin pages.
# Anyone with this value can call admin APIs from the browser — protect your Vercel deployment.
NEXT_PUBLIC_ADMIN_API_KEY=

# --- Optional ---
# Shown in admin UI for dev-safe inbox hints; does not grant access by itself.
NEXT_PUBLIC_DEV_INBOX=monitoring@yourdomain.com

# Local development only: where Next.js rewrites /fastapi/* (see next.config.mjs).
# Not required on Vercel when NEXT_PUBLIC_API_URL points at Render.
FASTAPI_INTERNAL_URL=http://127.0.0.1:8000
